{
  "name": "conferencehub",
  "version": "1.0.0",
  "description": "ConferenceHub PERN Stack",
  "main": "api/index.js",
  "scripts": {
    "start": "cd api && node index.js",
    "dev:api": "cd api && nodemon index.js",
    "dev:client": "cd client && npm run dev",
    "dev": "concurrently \"npm run dev:api\" \"npm run dev:client\"",
    "build": "cd client && npm install && npm run build",
    "render-postbuild": "npm install"
  },
  "dependencies": {
    "@cloudinary/react": "^1.14.1",
    "@cloudinary/url-gen": "^1.21.0",
    "@vitejs/plugin-react": "^4.0.3",
    "axios": "^1.5.0",
    "base-64": "^1.0.0",
    "bcryptjs": "^2.4.3",
    "body-parser": "^1.20.2",
    "cheerio": "^1.0.0-rc.12",
    "cloudinary": "^2.6.0",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "^4.18.2",
    "express-session": "^1.18.1",
    "form-data": "^4.0.3",
    "i18next": "^25.3.2",
    "i18next-fs-backend": "^2.6.0",
    "image-downloader": "^4.3.0",
    "jsonwebtoken": "^9.0.2",
    "md5": "^2.3.0",
    "multer": "^1.4.5-lts.1",
    "node-cache": "^5.1.2",
    "pg": "^8.14.1",
    "react-country-flag": "^3.1.0",
    "react-router-dom": "^6.15.0",
    "sequelize": "^6.37.7",
    "sequelize-cli": "^6.6.2",
    "streamifier": "^0.1.1",
    "vite": "^6.3.5"
  },
  "devDependencies": {
    "concurrently": "^8.2.1",
    "nodemon": "^3.0.1"
  },
  "engines": {
    "node": ">=14"
  }
}
